[
  {
    "label": "Debug auth-service",
    "adapter": "Delve",
    "request": "launch",
    "mode": "debug",
    "program": "${ZED_WORKTREE_ROOT}/cmd/server",
    "env": {
      "DATABASE_URL": "postgres://auth:secret@localhost:5432/authdb?sslmode=disable",
      "REDIS_URL": "redis://localhost:6379",
      "JWT_SECRET": "change-me-to-a-long-random-secret",
    },
  },
]
